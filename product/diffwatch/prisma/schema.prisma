generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Monitor {
  id          String     @id @default(cuid())
  url         String
  name        String
  selector    String?
  interval    String     @default("daily")
  active      Boolean    @default(true)
  snapshots   Snapshot[]
  changes     Change[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Snapshot {
  id         String   @id @default(cuid())
  monitorId  String
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  content    String
  hash       String
  createdAt  DateTime @default(now())
}

model Change {
  id         String   @id @default(cuid())
  monitorId  String
  monitor    Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  category   String   @default("content")
  summary    String
  diff       String
  importance String   @default("low")
  createdAt  DateTime @default(now())
}
